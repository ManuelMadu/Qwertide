@* Renders the target passage one glyph per <span> (PDD §5.2). Consecutive
   non-space glyphs are grouped into a .q-word wrapper (white-space: nowrap) so a
   word never breaks across lines; the passage wraps only at the standalone space
   spans between words. State per glyph: correct / incorrect / current (caret rides
   it) / upcoming. Pure render: all logic lives in Play.razor. *@

<div class="q-passage @(Blurred ? "is-blurred" : null)" aria-hidden="true">
    @{ var i = 0; }
    @while (i < Target.Length)
    {
        if (Target[i] == ' ')
        {
            var s = i;
            <span class="char space @ClassFor(s)" id="@CaretId(s)">@(' ')</span>
            i++;
        }
        else
        {
            var start = i;
            while (i < Target.Length && Target[i] != ' ') { i++; }
            var end = i;
            <span class="q-word">@for (var j = start; j < end; j++)
                {
                    <span class="char @ClassFor(j)" id="@CaretId(j)">@Target[j]</span>
                }</span>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public string Target { get; set; } = "";
    [Parameter] public string Typed { get; set; } = "";
    [Parameter] public bool Blurred { get; set; }

    private string ClassFor(int i)
    {
        if (i < Typed.Length)
            return Typed[i] == Target[i] ? "correct" : "incorrect";
        if (i == Typed.Length && !Blurred)
            return "current"; // caret rides this glyph
        return string.Empty;  // upcoming: inherits the dim --text-muted base
    }

    private string? CaretId(int i) => (i == Typed.Length && !Blurred) ? "q-caret" : null;
}
